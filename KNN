import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.neighbors import KNeighborsClassifier

from sklearn import datasets


data1  =  datasets.load_wine()

x = data1.data

y=  data1.target



x_train,x_test,y_train,y_test = train_test_split(x,y,test_size  = 0.2, random_state = 42)
sc =  StandardScaler()
sc.fit_transform(x_train)
sc.transform(x_test)
#optial value k
error_rate  =  []
for i in range(1,50):
    knn1   =  KNeighborsClassifier(n_neighbors  =  i)
    knn1.fit(x_train , y_train)
    prediction2  =  knn1.predict(x_test)
    accuracy1  =  np.mean(prediction2  == y_test)
    error_rate_value = 1  - accuracy1
    error_rate.append(error_rate_value)
#plotting knn graph
plt.figure(figsize = (5,5))
plt.plot(range(1,50),error_rate,marker = 'o',lw = 1.5,markerfacecolor  =  'red',markeredgecolor  =  'blue')
plt.show()
#prediction
knn  =  KNeighborsClassifier(n_neighbors  =  35)
knn.fit(x_train,y_train)
prediction  =  knn.predict(x_test)
print(prediction)
#Accuracy
accuracy  =  np.mean(prediction  ==y_test)*100
print(accuracy)
#confusion matrix display
from sklearn.metrics import ConfusionMatrixDisplay
from sklearn.metrics import confusion_matrix
fig, axes  =  plt.subplots(1,1,figsize   =(5,5))
confusion_m  =  confusion_matrix(prediction  , y_test)
confusion_m_d = ConfusionMatrixDisplay(confusion_matrix  =  confusion_m , display_labels = np.unique(y_test))
confusion_m_d.plot(ax  =  axes)
plt.show()
